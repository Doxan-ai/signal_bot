# TradingView дан сигнал олиш функцияси
def get_signal():
    try:
        # EURUSD (OTC бўлмаган вақтда) ёки бошқа жуфтлик
        handler = TA_Handler(
            symbol="EURUSD",
            screener="forex",
            exchange="FX_IDC",
            interval=Interval.INTERVAL_1_MINUTE
        )
        analysis = handler.get_analysis()
        recommendation = analysis.summary['RECOMMENDATION']
        buy_score = analysis.summary['BUY']
        sell_score = analysis.summary['SELL']
        
        return recommendation, buy_score, sell_score
    except:
        return "ERROR", 0, 0

@bot.message_handler(commands=['start'])
def start(message):
    # Реферал ссылкани текшириш (ID тизими учун асос)
    args = message.text.split()
    
    markup = types.ReplyKeyboardMarkup(resize_keyboard=True)
    btn1 = types.KeyboardButton("📊 СИГНАЛ ОЛИШ")
    btn2 = types.KeyboardButton("👥 ДЎСТЛАРНИ ТАКЛИФ ҚИЛИШ")
    btn3 = types.KeyboardButton("🆔 ID ТЕКШИРИШ")
    markup.add(btn1)
    markup.add(btn2, btn3)
    
    welcome_text = (
        "👋 Хуш келибсиз!\n\n"
        "📈 Бу бот TradingView алгоритмлари асосида Pocket Option учун сигналлар беради.\n\n"
        "❗ Сигнал олиш учун пастдаги тугмани босинг."
    )
    bot.send_message(message.chat.id, welcome_text, reply_markup=markup)

@bot.message_handler(func=lambda m: m.text == "📊 СИГНАЛ ОЛИШ")
def send_signal(message):
    wait_msg = bot.send_message(message.chat.id, "🔍 Бозор таҳлил қилинмоқда, кутинг...")
    
    status, buy, sell = get_signal()
    
    if status == "ERROR":
        bot.edit_message_text("❌ Хатолик: Биржа маълумотларини олиб бўлмади.", message.chat.id, wait_msg.message_id)
        return

    # Сигналга қараб рангли белгилар
    icon = "⏳"
    if "BUY" in status: icon = "✅ СИТИБ ОЛИШ (CALL)"
    if "SELL" in status: icon = "🔴 СОТИШ (PUT)"
    
    result = (
        f"💎 **ЯНГИ СИГНАЛ** 💎\n\n"
        f"💹 Актив: EUR/USD\n"
        f"📈 Йўналиш: {icon}\n"
        f"📊 Куч: {status}\n"
        f"⏱ Вақт: 1 МИНУТ\n\n"
        f"👍 Ишонч: {max(buy, sell)}%"
    )
    bot.edit_message_text(result, message.chat.id, wait_msg.message_id, parse_mode="Markdown")

